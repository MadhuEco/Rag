<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="Exercise 3 — Variant A: Azure-Native Hand-Built Teams Bot" id="variant-a-model" version="5.0.0">
  <folder name="Strategy" id="id-1337746d609e4f1aac561633f4887c10" type="strategy"/>
  <folder name="Motivation" id="f-motivation" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Frontline Colleague" id="m-sh-frontline"/>
    <element xsi:type="archimate:Stakeholder" name="BU Knowledge Manager" id="m-sh-km"/>
    <element xsi:type="archimate:Stakeholder" name="IT / Cloud Platform Team" id="m-sh-it"/>
    <element xsi:type="archimate:Stakeholder" name="Legal &amp; Compliance" id="m-sh-legal"/>
    <element xsi:type="archimate:Driver" name="SharePoint search insufficient for SOP retrieval" id="m-dr-search"/>
    <element xsi:type="archimate:Driver" name="EU data residency mandate" id="m-dr-dataresidency"/>
    <element xsi:type="archimate:Driver" name="Permission-aware answers required" id="m-dr-acl"/>
    <element xsi:type="archimate:Assessment" name="Risk: user sees out-of-ACL content" id="m-as-aclrisk"/>
    <element xsi:type="archimate:Assessment" name="Risk: vendor lock-in if fully Copilot Studio" id="m-as-lockin"/>
    <element xsi:type="archimate:Goal" name="Answer questions from 8,000 SharePoint docs via Teams" id="m-g-answer"/>
    <element xsi:type="archimate:Goal" name="Enforce SharePoint ACL at retrieval time" id="m-g-acl"/>
    <element xsi:type="archimate:Goal" name="All data stays in EU Azure region" id="m-g-eu"/>
    <element xsi:type="archimate:Goal" name="Support multi-turn conversations" id="m-g-multiturn"/>
    <element xsi:type="archimate:Goal" name="Extensible to new tools (SAP, Snowflake)" id="m-g-extensible"/>
    <element xsi:type="archimate:Requirement" name="REQ-01: SSO via Entra ID — no separate login" id="m-req-sso"/>
    <element xsi:type="archimate:Requirement" name="REQ-02: Per-user ACL trimming on every query" id="m-req-acl"/>
    <element xsi:type="archimate:Requirement" name="REQ-03: Answers include citations to source document" id="m-req-cite"/>
    <element xsi:type="archimate:Requirement" name="REQ-04: Conversation history retained per session" id="m-req-history"/>
    <element xsi:type="archimate:Requirement" name="REQ-05: Data stays in West Europe Azure region" id="m-req-eu"/>
    <element xsi:type="archimate:Principle" name="Prefer Azure-native PaaS over IaaS" id="m-pr-paas"/>
    <element xsi:type="archimate:Principle" name="Least-privilege at every boundary" id="m-pr-leastpriv"/>
  </folder>
